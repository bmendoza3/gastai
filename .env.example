# LLM — Ollama local (default) o cualquier proveedor OpenAI-compatible
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:3b
LLM_API_KEY=ollama

# Para usar Claude en producción:
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_API_KEY=sk-ant-...

# Meta WhatsApp Cloud API
META_PHONE_NUMBER_ID=your_phone_number_id
META_ACCESS_TOKEN=your_access_token
META_VERIFY_TOKEN=gastai_verify

# Gmail API
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Budgets (CLP semanal por categoría)
DELIVERY_WEEKLY_LIMIT_CLP=
SUPERMERCADO_WEEKLY_LIMIT_CLP=
